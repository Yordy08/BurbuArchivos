{"file":"index-CZGbNFUn.js","mappings":";;;;;;;;;;;;;;;;;;;;;;AA0LA,UAAM;AAAA,MACJ;AAAA,MACA;AAAA,MACA;AAAA,IACF,KAAI,CAAA,QAAA,SAAA,IAAAA,iBAAA,MAAM;AAAA,MAAS;AAAA,MAAa;AAAA;AAAA,KAAC;AAEjC,UAAM,OAAO,SAAS,MAAM,KAAK,OAAO,QAAQ,IAAI;AAEpD,UAAM,WAAW,SAAS,MAAM;AAC9B,UAAI,CAAC,KAAK,OAAO,KAAM,QAAO;AAE9B,aAAO,KAAK,MAAM,KACf,MAAM,GAAG,EACT,IAAI,UAAQ,KAAK,CAAC,CAAC,EACnB,KAAK,EAAE,EACP,UAAU,GAAG,CAAC,EACd,YAAW;AAAA,IAChB,CAAC;AAED,UAAM,iBAAiB,SAAS,MAAM;AACpC,UAAI,CAAC,KAAK,OAAO,OAAQ,QAAO;AAEhC,aAAO,KAAK,MAAM,OAAO;AAAA,QACvB,CAAC,OAAO,QAAQ,SAAS,IAAI,aAAa;AAAA,QAC1C;AAAA,MACJ;AAAA,IACA,CAAC;AAED,UAAM,aAAa,CAAC,SAAS;AAC3B,aAAO,IAAI,KAAK,IAAI,EAAE,mBAAkB;AAAA,IAC1C;AAGA,UAAM,cAAc,SAAS;AAAA,MAC3B,MAAM;AAAA,MACN,OAAO;AAAA,IACT,CAAC;AAED,UAAM,iBAAiB,IAAI,KAAK;AAChC,UAAM,iBAAiB,IAAI,EAAE;AAC7B,UAAM,eAAe,IAAI,KAAK;AAE9B,UAAM,MAAM,KAAK,OAAO,CAAC,MAAM;AAC7B,UAAI,GAAG;AACL,oBAAY,OAAO,EAAE,QAAQ;AAC7B,oBAAY,QAAQ,EAAE,SAAS;AAAA,MACjC;AAAA,IACF,GAAG,EAAE,WAAW,MAAM;AA6BtB,UAAM,eAAe,SAAS;AAAA,MAC5B,iBAAiB;AAAA,MACjB,aAAa;AAAA,MACb,iBAAiB;AAAA,IACnB,CAAC;AAED,UAAM,kBAAkB,IAAI,KAAK;AACjC,UAAM,kBAAkB,IAAI,EAAE;AAC9B,UAAM,gBAAgB,IAAI,KAAK;;;AA7QxB,YAAA,OAAAC,eAAAC,WAAA,EAAA,OAAM,oBAAgB,MAAA,CAAA,CAAA,GAAA;UAGdC,MAAA,OAAA,GAAO;;iBAOF,KAAA,OAAI;6SAWV,EAAA,SAAA,QAAA,UAAA,QAAA,aAAA,QAAA,eAAA,OAAA,CAA+D,qBAE5D,SAAA,KAAQ,+CAIRC,eAAA,KAAA,MAAK,IAAI,oCAITA,eAAA,KAAA,MAAK,KAAK,gEAIVA,eAAA,KAAA,MAAK,IAAI,8GAQL,KAAA,MAAK,QAAQ,UAAM,CAAA,2HAOnB,eAAA,KAAc;YAcZ,eAAA,OAAc;wDAAoB,aAAA,QAAY,iBAAA,eAAA,CAAA,qBACpD,eAAA,KAAc;;;;8DAKDC,cAAA,SAAA,YAAY,IAAI,0EAEhBA,cAAA,SAAA,YAAY,KAAK,oJAEoC,eAAA,KAAc,IAAA,cAAA;YACrE,eAAA,OAAc;;;;;;YAanB,gBAAA,OAAe;wDAAoB,cAAA,QAAa,iBAAA,eAAA,CAAA,qBACtD,gBAAA,KAAe;;;;8DAKFA,cAAA,SAAA,aAAa,eAAe,8EAE5BA,cAAA,SAAA,aAAa,WAAW,6EAExBA,cAAA,SAAA,aAAa,eAAe,wJAEuB,gBAAA,KAAe,IAAA,cAAA;YACpE,gBAAA,OAAe;;;;;;;UAgBvB,IAAG;AAAA,UAAS,OAAM;AAAA;2BAA5B,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;;;gCAFoD,iBAE/D;AAAA;;;;;;YAIS,KAAA,MAAK,QAAQ,QAAM;;wBAGV,KAAA,MAAK,QAAM,CAApB,UAAK;8GAOP,OAAK,MAAM,WAAW,gDAEvB,EAAA,UAAA,SAAA,cAAA,QAAA,CAAsC,6DAMjCH,eAAA,MAAM,KAAK,mEAIR,WAAW,MAAM,SAAS,CAAA,sDAI3BA,eAAA,MAAM,SAAS;;cAInB,IAAE,SAAW,MAAM,IAAI;AAAA,cACxB,OAAM;AAAA;+BAFR,CAKW,GAAAE,QAAAC,UAAA,aAAA;;;;;oCAFV,OAED;AAAA;;;;;;;;;;;;;;;;;;;;;;;;;","names":["_withAsyncContext","_ssrRenderAttrs","_mergeProps","_unref","_ssrInterpolate","_ssrRenderAttr","_push","_parent"],"sources":["../../../../pages/perfil/index.vue"],"sourcesContent":["<template>\r\n  <div class=\"container py-5\">\r\n\r\n    <!-- Cargando -->\r\n    <div v-if=\"pending\" class=\"text-center py-5\">\r\n      <div class=\"spinner-border text-danger\" role=\"status\">\r\n        <span class=\"visually-hidden\">Cargando...</span>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Perfil -->\r\n    <div v-else-if=\"user\" class=\"row g-5\">\r\n\r\n      <!-- Columna izquierda -->\r\n      <div class=\"col-lg-4 d-flex flex-column gap-4\">\r\n\r\n        <!-- Perfil card -->\r\n        <div class=\"card shadow border-0 rounded-4\">\r\n          <div class=\"card-body text-center p-4\">\r\n\r\n            <div\r\n              class=\"rounded-circle bg-danger text-white d-flex align-items-center justify-content-center mx-auto mb-3\"\r\n              style=\"width:90px;height:90px;font-size:2rem;font-weight:bold;\"\r\n            >\r\n              {{ initials }}\r\n            </div>\r\n\r\n            <h2 class=\"fw-bold text-danger mb-1\">\r\n              {{ user.name }}\r\n            </h2>\r\n\r\n            <p class=\"text-muted mb-2\">\r\n              {{ user.email }}\r\n            </p>\r\n\r\n            <span class=\"badge bg-dark px-3 py-2 rounded-pill mb-3\">\r\n              {{ user.role }}\r\n            </span>\r\n\r\n            <hr>\r\n\r\n            <div class=\"row text-center\">\r\n              <div class=\"col-6\">\r\n                <h4 class=\"fw-bold text-danger\">\r\n                  {{ user.images?.length || 0 }}\r\n                </h4>\r\n                <small class=\"text-muted\">Imágenes</small>\r\n              </div>\r\n\r\n              <div class=\"col-6\">\r\n                <h4 class=\"fw-bold text-danger\">\r\n                  {{ totalDownloads }}\r\n                </h4>\r\n                <small class=\"text-muted\">Descargas</small>\r\n              </div>\r\n            </div>\r\n\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Editar perfil -->\r\n        <div class=\"card shadow border-0 rounded-4\">\r\n          <div class=\"card-body p-4\">\r\n            <h5 class=\"fw-bold text-danger mb-3\">✏️ Editar Perfil</h5>\r\n\r\n            <div v-if=\"profileMessage\" :class=\"['alert', profileError ? 'alert-danger' : 'alert-success']\">\r\n              {{ profileMessage }}\r\n            </div>\r\n\r\n            <form @submit.prevent=\"updateProfile\" class=\"d-flex flex-column gap-3\">\r\n\r\n              <input v-model=\"profileForm.name\" type=\"text\" class=\"form-control\" placeholder=\"Nombre\" required />\r\n\r\n              <input v-model=\"profileForm.email\" type=\"email\" class=\"form-control\" placeholder=\"Correo\" required />\r\n\r\n              <button type=\"submit\" class=\"btn btn-danger rounded-pill\" :disabled=\"profileLoading\">\r\n                <span v-if=\"profileLoading\" class=\"spinner-border spinner-border-sm me-2\"></span>\r\n                Guardar Cambios\r\n              </button>\r\n\r\n            </form>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Cambiar contraseña -->\r\n        <div class=\"card shadow border-0 rounded-4\">\r\n          <div class=\"card-body p-4\">\r\n            <h5 class=\"fw-bold text-danger mb-3\">🔒 Contraseña</h5>\r\n\r\n            <div v-if=\"passwordMessage\" :class=\"['alert', passwordError ? 'alert-danger' : 'alert-success']\">\r\n              {{ passwordMessage }}\r\n            </div>\r\n\r\n            <form @submit.prevent=\"updatePassword\" class=\"d-flex flex-column gap-3\">\r\n\r\n              <input v-model=\"passwordForm.currentPassword\" type=\"password\" class=\"form-control\" placeholder=\"Actual\" required />\r\n\r\n              <input v-model=\"passwordForm.newPassword\" type=\"password\" class=\"form-control\" placeholder=\"Nueva\" required />\r\n\r\n              <input v-model=\"passwordForm.confirmPassword\" type=\"password\" class=\"form-control\" placeholder=\"Confirmar\" required />\r\n\r\n              <button type=\"submit\" class=\"btn btn-dark rounded-pill\" :disabled=\"passwordLoading\">\r\n                <span v-if=\"passwordLoading\" class=\"spinner-border spinner-border-sm me-2\"></span>\r\n                Actualizar\r\n              </button>\r\n\r\n            </form>\r\n          </div>\r\n        </div>\r\n\r\n      </div>\r\n\r\n      <!-- Columna derecha -->\r\n      <div class=\"col-lg-8\">\r\n\r\n        <div class=\"d-flex justify-content-between align-items-center mb-4\">\r\n          <h3 class=\"fw-bold text-danger mb-0\">🖼️ Mis Imágenes</h3>\r\n\r\n          <NuxtLink to=\"/subir\" class=\"btn btn-danger rounded-pill px-4\">\r\n            + Subir Nueva\r\n          </NuxtLink>\r\n        </div>\r\n\r\n        <!-- Galería -->\r\n        <div v-if=\"user.images?.length\" class=\"row g-4\">\r\n\r\n          <div\r\n            v-for=\"image in user.images\"\r\n            :key=\"image.id\"\r\n            class=\"col-md-6 col-xl-4\"\r\n          >\r\n            <div class=\"card shadow border-0 h-100\">\r\n\r\n              <img\r\n                :src=\"image.urlOriginal\"\r\n                class=\"card-img-top\"\r\n                style=\"height:200px;object-fit:cover;\"\r\n              />\r\n\r\n              <div class=\"card-body\">\r\n\r\n                <h6 class=\"fw-bold text-danger\">\r\n                  {{ image.title }}\r\n                </h6>\r\n\r\n                <small class=\"text-muted d-block mb-2\">\r\n                  📅 {{ formatDate(image.createdAt) }}\r\n                </small>\r\n\r\n                <small class=\"text-muted d-block mb-3\">\r\n                  ⬇ {{ image.downloads }} descargas\r\n                </small>\r\n\r\n                <NuxtLink\r\n                  :to=\"`/foto/${image.slug}`\"\r\n                  class=\"btn btn-outline-dark btn-sm w-100 rounded-pill\"\r\n                >\r\n                  Ver\r\n                </NuxtLink>\r\n\r\n              </div>\r\n\r\n            </div>\r\n          </div>\r\n\r\n        </div>\r\n\r\n        <div v-else class=\"alert alert-warning text-center\">\r\n          No has subido imágenes todavía.\r\n        </div>\r\n\r\n      </div>\r\n\r\n    </div>\r\n\r\n    <!-- No user -->\r\n    <div v-else class=\"alert alert-danger text-center\">\r\n      Usuario no encontrado o sesión expirada.\r\n    </div>\r\n\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { computed, reactive, ref, watch } from 'vue'\r\n\r\nconst {\r\n  data,\r\n  pending,\r\n  refresh\r\n} = await useFetch('/api/auth/me')\r\n\r\nconst user = computed(() => data.value?.user || null)\r\n\r\nconst initials = computed(() => {\r\n  if (!user.value?.name) return 'U'\r\n\r\n  return user.value.name\r\n    .split(' ')\r\n    .map(word => word[0])\r\n    .join('')\r\n    .substring(0, 2)\r\n    .toUpperCase()\r\n})\r\n\r\nconst totalDownloads = computed(() => {\r\n  if (!user.value?.images) return 0\r\n\r\n  return user.value.images.reduce(\r\n    (total, img) => total + (img.downloads || 0),\r\n    0\r\n  )\r\n})\r\n\r\nconst formatDate = (date) => {\r\n  return new Date(date).toLocaleDateString()\r\n}\r\n\r\n// --- Editar Perfil ---\r\nconst profileForm = reactive({\r\n  name: '',\r\n  email: ''\r\n})\r\n\r\nconst profileLoading = ref(false)\r\nconst profileMessage = ref('')\r\nconst profileError = ref(false)\r\n\r\nwatch(() => user.value, (u) => {\r\n  if (u) {\r\n    profileForm.name = u.name || ''\r\n    profileForm.email = u.email || ''\r\n  }\r\n}, { immediate: true })\r\n\r\nconst updateProfile = async () => {\r\n  profileLoading.value = true\r\n  profileMessage.value = ''\r\n  profileError.value = false\r\n\r\n  try {\r\n    const res = await $fetch('/api/users/me', {\r\n      method: 'PUT',\r\n      body: {\r\n        name: profileForm.name,\r\n        email: profileForm.email\r\n      }\r\n    })\r\n\r\n    if (res.success) {\r\n      profileMessage.value = 'Perfil actualizado correctamente'\r\n      await refresh()\r\n    }\r\n  } catch (err) {\r\n    profileError.value = true\r\n    profileMessage.value = err?.data?.statusMessage || 'Error al actualizar el perfil'\r\n  } finally {\r\n    profileLoading.value = false\r\n  }\r\n}\r\n\r\n// --- Cambiar Contraseña ---\r\nconst passwordForm = reactive({\r\n  currentPassword: '',\r\n  newPassword: '',\r\n  confirmPassword: ''\r\n})\r\n\r\nconst passwordLoading = ref(false)\r\nconst passwordMessage = ref('')\r\nconst passwordError = ref(false)\r\n\r\nconst updatePassword = async () => {\r\n  passwordLoading.value = true\r\n  passwordMessage.value = ''\r\n  passwordError.value = false\r\n\r\n  try {\r\n    const res = await $fetch('/api/users/me/password', {\r\n      method: 'PUT',\r\n      body: {\r\n        currentPassword: passwordForm.currentPassword,\r\n        newPassword: passwordForm.newPassword,\r\n        confirmPassword: passwordForm.confirmPassword\r\n      }\r\n    })\r\n\r\n    if (res.success) {\r\n      passwordMessage.value = res.message\r\n      passwordForm.currentPassword = ''\r\n      passwordForm.newPassword = ''\r\n      passwordForm.confirmPassword = ''\r\n    }\r\n  } catch (err) {\r\n    passwordError.value = true\r\n    passwordMessage.value = err?.data?.statusMessage || 'Error al cambiar la contraseña'\r\n  } finally {\r\n    passwordLoading.value = false\r\n  }\r\n}\r\n</script>\r\n\r\n"],"version":3}