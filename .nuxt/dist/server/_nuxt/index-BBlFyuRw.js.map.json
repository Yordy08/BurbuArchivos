{"file":"index-BBlFyuRw.js","mappings":";;;;;;;;;;;;;;;AAoJA,UAAM,SAAS,IAAI,EAAE;AACrB,UAAM,UAAU,IAAI,IAAI;AACxB,UAAM,gBAAgB,IAAI,IAAI;AAC9B,UAAM,SAAS,IAAI,EAAE;AAmBrB,UAAM,iBAAiB,SAAS,MAAM;AACpC,UAAI,CAAC,OAAO,MAAO,QAAO,OAAO;AAEjC,YAAM,IAAI,OAAO,MAAM,YAAA;AAEvB,aAAO,OAAO,MAAM;AAAA,QAAO,CAAA,QACzB,IAAI,OAAO,YAAA,EAAc,SAAS,CAAC,KACnC,IAAI,MAAM,MAAM,YAAA,EAAc,SAAS,CAAC;AAAA,MAAA;AAAA,IAE5C,CAAC;;;QAlLM,OAAM;AAAA,QAA6B,OAAA,EAAA,cAAA,yBAAA;AAAA,MAAA,2EAGhB,EAAA,cAAA,wBAAA,CAAyC,kSAa5C,OAAA,KAAM;UAYZ,QAAA,OAAO;;MAKF,WAAA,eAAA,MAAe,WAAM,GAAA;;;;AASfA,sBAAA,eAAA,QAAT,UAAK;gKAQP,OAAK,MAAM,WAAW,gDAEvB,EAAA,UAAA,SAAA,cAAA,SAAA,UAAA,WAAqD,gIAOhDC,eAAA,MAAM,KAAK,oFAII,MAAM,MAAM,QAAI,SAAA,4DAI7BA,eAAA,MAAM,SAAS;AAaZ,cAAA,MAAM,cAAY;;;;;;;;;;UA8B3B,cAAA,OAAa;sHAId,OAAK,cAAA,MAAc,WAAW,kEAG/BA,eAAA,cAAA,MAAc,KAAK,kEAIhB,cAAA,MAAc,MAAM,IAAI;AAIxB,YAAA,cAAA,MAAc,cAAY;;;;;;;;;;;;;;;;;;;;","names":["_ssrRenderList","_ssrInterpolate"],"sources":["../../../../pages/index.vue"],"sourcesContent":["<template>\r\n  <div class=\"container-fluid min-vh-100\" style=\"background:rgba(250,250,250,0.75);\">\r\n\r\n    <!-- TÍTULO + BUSCADOR -->\r\n    <section class=\"py-4\" style=\"background:rgba(255,255,255,0.6);\">\r\n\r\n      <div class=\"container text-center mb-4\">\r\n\r\n        <p class=\"text-muted\">\r\n          Explora imágenes compartidas por la comunidad\r\n        </p>\r\n\r\n        <!-- 🔥 BUSCADOR -->\r\n        <div class=\"row justify-content-center\">\r\n          <div class=\"col-md-6\">\r\n\r\n            <input\r\n              v-model=\"search\"\r\n              type=\"text\"\r\n              class=\"form-control form-control-lg\"\r\n              placeholder=\"🔍 Buscar por título o usuario...\"\r\n            />\r\n\r\n          </div>\r\n        </div>\r\n\r\n      </div>\r\n\r\n      <!-- LOADING -->\r\n      <div v-if=\"loading\" class=\"text-center py-5\">\r\n        <div class=\"spinner-border text-danger\"></div>\r\n      </div>\r\n\r\n      <!-- EMPTY -->\r\n      <div v-else-if=\"filteredImages.length === 0\" class=\"alert alert-warning text-center\">\r\n        No hay imágenes encontradas.\r\n      </div>\r\n\r\n      <!-- GRID -->\r\n      <div v-else class=\"container\">\r\n        <div class=\"row g-4\">\r\n\r\n          <div\r\n            v-for=\"image in filteredImages\"\r\n            :key=\"image.id\"\r\n            class=\"col-md-6 col-lg-4 col-xl-3\"\r\n          >\r\n\r\n            <div class=\"card shadow border-0 h-100 hover-card\">\r\n\r\n              <img\r\n                :src=\"image.urlOriginal\"\r\n                class=\"card-img-top\"\r\n                style=\"height:220px;object-fit:cover;cursor:pointer;\"\r\n                @click=\"openModal(image)\"\r\n              />\r\n\r\n              <div class=\"card-body d-flex flex-column\">\r\n\r\n                <h5 class=\"fw-bold text-danger\">\r\n                  {{ image.title }}\r\n                </h5>\r\n\r\n                <p class=\"small text-muted\">\r\n                  Publicado por: {{ image.user?.name || 'Usuario' }}\r\n                </p>\r\n\r\n                <p class=\"small text-muted mb-2\">\r\n                  ⬇ {{ image.downloads }} descargas\r\n                </p>\r\n\r\n                <div class=\"mt-auto d-grid gap-2\">\r\n\r\n                  <button\r\n                    class=\"btn btn-outline-dark rounded-pill\"\r\n                    @click=\"openModal(image)\"\r\n                  >\r\n                    👁 Ver Imagen\r\n                  </button>\r\n\r\n                  <button\r\n                    v-if=\"image.downloadable\"\r\n                    class=\"btn btn-danger rounded-pill\"\r\n                    @click=\"downloadImage(image)\"\r\n                  >\r\n                    ⬇ Descargar\r\n                  </button>\r\n\r\n                  <button\r\n                    v-else\r\n                    disabled\r\n                    class=\"btn btn-secondary rounded-pill\"\r\n                  >\r\n                    ❌ Descarga bloqueada\r\n                  </button>\r\n\r\n                </div>\r\n\r\n              </div>\r\n\r\n            </div>\r\n\r\n          </div>\r\n\r\n        </div>\r\n      </div>\r\n\r\n    </section>\r\n\r\n    <!-- MODAL -->\r\n    <transition name=\"fade\">\r\n      <div v-if=\"selectedImage\" class=\"modal-backdrop\" @click=\"closeModal\">\r\n\r\n        <div class=\"modal-box\" @click.stop>\r\n\r\n          <img :src=\"selectedImage.urlOriginal\" />\r\n\r\n          <h5 class=\"mt-3 text-danger\">\r\n            {{ selectedImage.title }}\r\n          </h5>\r\n\r\n          <p class=\"text-muted\">\r\n            👤 {{ selectedImage.user?.name }}\r\n          </p>\r\n\r\n          <button\r\n            v-if=\"selectedImage.downloadable\"\r\n            class=\"btn btn-danger w-100\"\r\n            @click=\"downloadImage(selectedImage)\"\r\n          >\r\n            ⬇ Descargar\r\n          </button>\r\n\r\n          <button class=\"btn btn-secondary w-100 mt-2\" @click=\"closeModal\">\r\n            Cerrar\r\n          </button>\r\n\r\n        </div>\r\n\r\n      </div>\r\n    </transition>\r\n\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted } from 'vue'\r\n\r\nconst images = ref([])\r\nconst loading = ref(true)\r\nconst selectedImage = ref(null)\r\nconst search = ref('')\r\n\r\nonMounted(async () => {\r\n  await loadImages()\r\n})\r\n\r\nconst loadImages = async () => {\r\n  try {\r\n    loading.value = true\r\n    const res = await fetch('/api/images')\r\n    images.value = await res.json()\r\n  } catch (e) {\r\n    console.error(e)\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\n/* 🔥 FILTRO BUSCADOR */\r\nconst filteredImages = computed(() => {\r\n  if (!search.value) return images.value\r\n\r\n  const s = search.value.toLowerCase()\r\n\r\n  return images.value.filter(img =>\r\n    img.title?.toLowerCase().includes(s) ||\r\n    img.user?.name?.toLowerCase().includes(s)\r\n  )\r\n})\r\n\r\nconst openModal = (img) => {\r\n  selectedImage.value = img\r\n  document.body.style.overflow = 'hidden'\r\n}\r\n\r\nconst closeModal = () => {\r\n  selectedImage.value = null\r\n  document.body.style.overflow = 'auto'\r\n}\r\n\r\nconst downloadImage = async (image) => {\r\n  try {\r\n    await fetch('/api/images/download', {\r\n      method: 'POST',\r\n      headers: { 'Content-Type': 'application/json' },\r\n      body: JSON.stringify({ id: image.id })\r\n    })\r\n\r\n    const link = document.createElement('a')\r\n    link.href = image.urlOriginal.replace('/upload/', '/upload/fl_attachment/')\r\n    link.click()\r\n\r\n  } catch (e) {\r\n    console.error(e)\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.hover-card {\r\n  transition: 0.3s;\r\n}\r\n\r\n.hover-card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 10px 25px rgba(0,0,0,0.15);\r\n}\r\n\r\n.modal-backdrop {\r\n  position: fixed;\r\n  inset: 0;\r\n  background: rgba(0,0,0,0.6);\r\n  backdrop-filter: blur(6px);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  z-index: 9999;\r\n}\r\n\r\n.modal-box {\r\n  background: white;\r\n  padding: 15px;\r\n  border-radius: 14px;\r\n  max-width: 600px;\r\n  width: 90%;\r\n  text-align: center;\r\n}\r\n\r\n.modal-box img {\r\n  width: 100%;\r\n  border-radius: 12px;\r\n}\r\n</style>"],"version":3}